{
    "name": "philiprehberger/php-crypt",
    "description": "Secure-by-default encryption with AES-256-GCM and key rotation",
    "keywords": ["encryption", "aes-256-gcm", "crypto", "key-rotation", "openssl", "security"],
    "homepage": "https://github.com/philiprehberger/php-crypt",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-openssl": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\Crypt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\Crypt\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
